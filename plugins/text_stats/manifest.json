{
  "apiVersion": "plugin.exec/v1",
  "kind": "Plugin",
  "metadata": {
    "name": "text_stats",
    "displayName": "Text Stats",
    "version": "1.0.0",
    "description": "Compute character, word and line statistics for input.text.",
    "license": "Apache-2.0"
  },
  "runtime": {
    "type": "process",
    "protocol": "stdio-json",
    "entrypoint": "python3",
    "args": ["run.py"],
    "timeoutSeconds": 5
  },
  "compat": {"coreApi": "v1", "protocolVersion": 1},
  "capabilities": ["task.execute", "text.analyze"],
  "permissions": {"network": "none", "fs": []},
  "resources": {"memory": "64Mi", "pids": 8},
  "security": {"checksum": "dev-local"}
}
